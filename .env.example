# CommitCrew environment variables
# Copy this file to .env.local or .env and replace values with your own.
# Never commit real secrets, tokens, database keys, or bot auth files.

# AI scoring
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Bot configuration
BOT_PROVIDER=demo
PRODUCTIVITY_GROUP_ID=demo-group-id
ALLOWED_GROUP_IDS=demo-group-id
COMMIT_API_KEY=replace_with_random_secret

# Dashboard authentication
JWT_SECRET=replace_with_long_random_secret
SHARED_DASHBOARD_PASSWORD_HASH=replace_with_sha256_hash
SESSION_VERSION=1

# Local/demo mode
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true
