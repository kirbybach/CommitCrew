# CommitCrew environment variables
# Copy this file to .env.local or .env and replace placeholders with your own values.
# Never commit real secrets, tokens, database keys, bot auth state, or production data.

# Safe public-demo defaults
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# Web dashboard, required only when NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
JWT_SECRET=replace_with_long_random_secret
SHARED_DASHBOARD_PASSWORD_HASH=replace_with_sha256_hash
SESSION_VERSION=1
GITHUB_TOKEN=optional_github_token_for_changelog

# Bot/database/AI integrations, required only when DEMO_MODE=false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-nano
COMMIT_API_KEY=replace_with_random_secret
ALLOWED_GROUPS=demo-group-id
PRODUCTIVITY_GROUP_JID=demo-group-id
PHONE_NUMBER=
PORT=8080
DEBUG_RAG=false
